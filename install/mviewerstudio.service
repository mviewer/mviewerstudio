[Unit]
 Description=mviewerstudio
 After=network.target

 [Service]
 User=mviewer
 Environment="EXPORT_CONF_FOLDER=/home/user/git/mviewer/apps/store/"
 Environment="CONF_PUBLISH_PATH_FROM_MVIEWER=apps/prod"
 Environment="CONF_PATH_FROM_MVIEWER=apps/store"
 Environment="MVIEWERSTUDIO_PUBLISH_PATH=/home/user/git/mviewer/apps/prod"
 Environment="DEFAULT_ORG=public"
 Environment="LOG_LEVEL=INFO"
 WorkingDirectory=/home/user/git/mviewer/mviewerstudio
 ExecStart=/home/user/git/mviewerstudio/.venv/bin/gunicorn \
     -b 127.0.0.1:5007 \
     --workers=1 \
     --access-logfile /home/user/git/mviewerstudio/logs/gunicorn-access.log \
     --log-level info \
     --error-logfile /home/user/git/mviewerstudio/logs/gunicorn-error.log \
     src.app:app

 StandardOutput=append:/home/user/git/mviewerstudio/logs/mviewerstudio.log
 StandardError=append:/home/user/git/mviewerstudio/logs/mviewerstudio.log

 [Install]
 WantedBy=multi-user.target
